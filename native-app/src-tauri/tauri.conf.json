{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZZZ Tools",
  "version": "0.1.0",
  "identifier": "dev.zzz-tools",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZZZ Tools",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "externalBin": ["../sidecar/disc_capture"],
    "resources": ["../sidecar/*"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
